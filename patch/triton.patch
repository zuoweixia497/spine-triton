diff --git a/third_party/proton/csrc/lib/Profiler/Cpu/CpuProfiler.cpp b/third_party/proton/csrc/lib/Profiler/Cpu/CpuProfiler.cpp
new file mode 100644
index 000000000..61d2928cf
--- /dev/null
+++ b/third_party/proton/csrc/lib/Profiler/Cpu/CpuProfiler.cpp
@@ -0,0 +1,208 @@
+#include "Profiler/Cpu/CpuProfiler.h"
+#include <asm/unistd.h>
+#include <cerrno>
+#include <cstring>
+#include <iostream>
+#include <linux/perf_event.h>
+#include <sys/ioctl.h>
+#include <sys/syscall.h>
+#include <unistd.h>
+
+namespace proton {
+
+static long perf_event_open(struct perf_event_attr *hw_event, pid_t pid,
+                            int cpu, int group_fd, unsigned long flags) {
+  return syscall(__NR_perf_event_open, hw_event, pid, cpu, group_fd, flags);
+}
+
+CpuProfiler::CpuProfiler() {
+  std::cout << "[Proton] CpuProfiler constructed" << std::endl;
+}
+
+CpuProfiler::~CpuProfiler() {
+  // Close all perf event file descriptors
+  for (auto &c : counters) {
+    if (c.fd >= 0) {
+      close(c.fd);
+    }
+  }
+  counters.clear();
+}
+
+void CpuProfiler::setupCounters() {
+  struct perf_event_attr pe;
+  std::memset(&pe, 0, sizeof(struct perf_event_attr));
+  pe.type = PERF_TYPE_HARDWARE;
+  pe.size = sizeof(struct perf_event_attr);
+  pe.disabled = 1;
+  pe.exclude_kernel = 1;
+  pe.exclude_hv = 1;
+
+  // Cycles
+  pe.config = PERF_COUNT_HW_CPU_CYCLES;
+  int fd_cycles = perf_event_open(&pe, 0, -1, -1, 0);
+  if (fd_cycles != -1) {
+    std::cout << "[Proton] Successfully opened CPU Cycle counter." << std::endl;
+    counters.push_back({fd_cycles, "cycle"});
+  } else {
+    std::cerr << "[Proton] Warning: Failed to open cycles counter. Errno: "
+              << strerror(errno) << std::endl;
+  }
+
+  // Instructions
+  pe.config = PERF_COUNT_HW_INSTRUCTIONS;
+  int fd_inst = perf_event_open(&pe, 0, -1, -1, 0);
+  if (fd_inst != -1) {
+    std::cout << "[Proton] Successfully opened Instruction counter." << std::endl;
+    counters.push_back({fd_inst, "instruction"});
+  } else {
+    std::cerr << "[Proton] Warning: Failed to open instruction counter. Errno: "
+              << strerror(errno) << std::endl;
+  }
+}
+
+void CpuProfiler::doStart() {
+  std::cout << "[Proton] CpuProfiler::doStart()" << std::endl;
+  if (counters.empty()) {
+    setupCounters();
+  }
+  for (auto &c : counters) {
+    ioctl(c.fd, PERF_EVENT_IOC_RESET, 0);
+    ioctl(c.fd, PERF_EVENT_IOC_ENABLE, 0);
+  }
+}
+
+void CpuProfiler::doStop() {
+  std::cout << "[Proton] CpuProfiler::doStop()" << std::endl;
+  for (auto &c : counters) {
+    ioctl(c.fd, PERF_EVENT_IOC_DISABLE, 0);
+  }
+}
+
+void CpuProfiler::doFlush() {
+  // Nothing special to flush for CPU profiler
+}
+
+void CpuProfiler::doSetMode(const std::vector<std::string> &modeAndOptions) {
+  // CPU profiler doesn't need special mode configuration
+}
+
+void CpuProfiler::readCounters(std::map<std::string, uint64_t> &values) {
+  for (auto &c : counters) {
+    long long count;
+    int ret = read(c.fd, &count, sizeof(long long));
+    if (ret == sizeof(long long)) {
+      values[c.name] = count;
+    } else {
+      std::cerr << "[Proton Error] Failed to read " << c.name
+                << " ret=" << ret << " errno=" << strerror(errno) << std::endl;
+    }
+  }
+}
+
+// OpInterface implementation
+void CpuProfiler::startOp(const Scope &scope) {
+  // Delegate to enterScope for consistency
+  enterScope(scope);
+}
+
+void CpuProfiler::stopOp(const Scope &scope) {
+  // Delegate to exitScope for consistency
+  exitScope(scope);
+}
+
+void CpuProfiler::doAddMetrics(
+    size_t scopeId,
+    const std::map<std::string, MetricValueType> &scalarMetrics,
+    const std::map<std::string, TensorMetric> &tensorMetrics) {
+  // Add metrics to all registered data objects
+  for (auto *data : getDataSet()) {
+    data->addMetrics(scopeId, scalarMetrics);
+  }
+}
+
+// ScopeInterface implementation - supports nested scopes using stack
+void CpuProfiler::enterScope(const Scope &scope) {
+  std::cout << "[Proton Debug] enterScope: " << scope.name << " (scopeId="
+            << scope.scopeId << ", stack depth=" << scopeStack.size() << ")" << std::endl;
+
+  // Create new scope state
+  ScopeState state;
+  state.scopeId = scope.scopeId;
+  state.name = scope.name;
+
+  // Register this scope with all data objects
+  for (auto data : getDataSet()) {
+    auto internalScopeId = data->addOp(scope.scopeId, scope.name);
+    state.dataScopeIdMap[data] = internalScopeId;
+    std::cout << "[Proton Debug] Registered scope with data, internalScopeId="
+              << internalScopeId << std::endl;
+  }
+
+  // Read current counter values as start values
+  readCounters(state.startValues);
+
+  // Push state onto stack
+  scopeStack.push(std::move(state));
+
+  std::cout << "[Proton Debug] Start values recorded, stack depth now="
+            << scopeStack.size() << std::endl;
+}
+
+void CpuProfiler::exitScope(const Scope &scope) {
+  std::cout << "[Proton Debug] exitScope: " << scope.name << " (scopeId="
+            << scope.scopeId << ", stack depth=" << scopeStack.size() << ")" << std::endl;
+
+  if (scopeStack.empty()) {
+    std::cerr << "[Proton Error] exitScope called but stack is empty!" << std::endl;
+    return;
+  }
+
+  // Pop the top state from stack
+  ScopeState state = std::move(scopeStack.top());
+  scopeStack.pop();
+
+  // Verify scope matches (optional safety check)
+  if (state.scopeId != scope.scopeId) {
+    std::cerr << "[Proton Warning] Scope mismatch: expected " << state.scopeId
+              << " but got " << scope.scopeId << std::endl;
+  }
+
+  // Read end counter values
+  std::map<std::string, uint64_t> endValues;
+  readCounters(endValues);
+
+  // Calculate metrics (difference between end and start)
+  std::map<std::string, MetricValueType> metrics;
+  for (auto &c : counters) {
+    if (endValues.count(c.name) && state.startValues.count(c.name)) {
+      uint64_t diff = endValues[c.name] - state.startValues[c.name];
+      metrics[c.name] = static_cast<double>(diff);
+      std::cout << "[Proton Debug] Scope " << scope.name << " " << c.name
+                << ": " << diff << std::endl;
+    }
+  }
+
+  // Report metrics to all data objects using the saved dataScopeIdMap
+  if (!metrics.empty()) {
+    std::cout << "[Proton] Reporting metrics for scope " << scope.name
+              << " (dataScopeIdMap size: " << state.dataScopeIdMap.size() << ")"
+              << std::endl;
+    // Use current valid DataSet instead of saved pointers to avoid dangling pointers
+    for (auto *data : getDataSet()) {
+      auto it = state.dataScopeIdMap.find(data);
+      if (it != state.dataScopeIdMap.end()) {
+        std::cout << "[Proton Debug] Adding metrics to data for internalScopeId="
+                  << it->second << std::endl;
+        data->addMetrics(it->second, metrics);
+      }
+    }
+  } else {
+    std::cerr << "[Proton] No metrics recorded for scope " << scope.name << std::endl;
+  }
+
+  std::cout << "[Proton Debug] exitScope done, stack depth now="
+            << scopeStack.size() << std::endl;
+}
+
+} // namespace proton
