+#ifndef PROTON_RUNTIME_CPU_RUNTIME_H_
+#define PROTON_RUNTIME_CPU_RUNTIME_H_
+
+#include "Runtime/Runtime.h"
+#include <vector>
+#include <cstring>
+#include <cstdlib>
+
+namespace proton {
+
+class CpuRuntime : public Runtime {
+public:
+  CpuRuntime() : Runtime(DeviceType::CPU) {}
+  virtual ~CpuRuntime() = default;
+
+  static CpuRuntime &instance() {
+    static CpuRuntime instance;
+    return instance;
+  }
+
+  void launchKernel(void *kernel, unsigned int gridDimX, unsigned int gridDimY,
+                    unsigned int gridDimZ, unsigned int blockDimX,
+                    unsigned int blockDimY, unsigned int blockDimZ,
+                    unsigned int sharedMemBytes, void *stream,
+                    void **kernelParams, void **extra) override {
+      // No-op for CPU profiling currently
+  }
+
+  void memset(void *devicePtr, uint32_t value, size_t size,
+              void *stream) override {
+     std::memset(devicePtr, value, size);
+  }
+
+  void allocateHostBuffer(uint8_t **buffer, size_t size) override {
+     *buffer = (uint8_t *)std::malloc(size);
+  }
+
+  void freeHostBuffer(uint8_t *buffer) override {
+     std::free(buffer);
+  }
+
+  void allocateDeviceBuffer(uint8_t **buffer, size_t size) override {
+      // Unified memory on CPU
+      allocateHostBuffer(buffer, size);
+  }
+
+  void freeDeviceBuffer(uint8_t *buffer) override {
+      freeHostBuffer(buffer);
+  }
+
+  void copyDeviceToHostAsync(void *dst, const void *src, size_t size,
+                             void *stream) override {
+      std::memcpy(dst, src, size);
+  }
+
+  void *getDevice() override { return nullptr; }
+
+  void *getPriorityStream() override { return nullptr; }
+
+  void destroyStream(void *stream) override {}
+
+  void synchronizeStream(void *stream) override {}
+
+  void synchronizeDevice() override {}
+
+  void processHostBuffer(uint8_t *hostBuffer, size_t hostBufferSize,
+                         uint8_t *deviceBuffer, size_t deviceBufferSize,
+                         void *stream,
+                         std::function<void(uint8_t *, size_t)> callback) override {}
+};
+
+} // namespace proton
+
+#endif // PROTON_RUNTIME_CPU_RUNTIME_H_
