+// Helper function to recursively filter out nodes with empty metrics
+static void filterEmptyMetricsNodes(json &node) {
+  if (!node.contains("children") || !node["children"].is_array()) {
+    return;
+  }
+
+  json filteredChildren = json::array();
+  for (auto &child : node["children"]) {
+    // Recursively filter children first
+    filterEmptyMetricsNodes(child);
+
+    // Keep the child if it has non-empty metrics OR has non-empty children
+    bool hasMetrics = child.contains("metrics") &&
+                      child["metrics"].is_object() &&
+                      !child["metrics"].empty();
+    bool hasChildren = child.contains("children") &&
+                       child["children"].is_array() &&
+                       !child["children"].empty();
+
+    if (hasMetrics || hasChildren) {
+      filteredChildren.push_back(std::move(child));
+    }
+  }
+  node["children"] = std::move(filteredChildren);
+}
